{
  "name": "fragments",
  "version": "0.9.11",
  "private": true,
  "description": "Fragments back-end API",
  "scripts": {
    "test:watch": "jest -c jest.config.js --runInBand --watch --",
    "test": "jest -c jest.config.js --runInBand --",
    "coverage": "jest -c jest.config.js --runInBand --coverage",
    "lint": "eslint \"./src/**/*.js\" \"tests/**/*.js\"",
    "start0": "HTPASSWD_FILE=${HTPASSWD_FILE=tests/test.httpasswd} node src/index.js",
    "start": "node src/index.js",
    "dev": "node --env-file=.env.debug --watch ./src/index.js",
    "debug": "node --env-file=.env.debug --inspect=0.0.0.0:9229 --watch ./src/index.js",
    "test:integration": "docker run --rm -v C:/Users/Kaung/Downloads/cloud-for-programmers/fragments:/workspace -w /workspace ghcr.io/orange-opensource/hurl:latest --test --glob \"tests/integration/**/*.hurl\""
  },
  "jest": {
    "setupFiles": [
      "<rootDir>/tests/setup.js"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Kaung224/fragments.git"
  },
  "author": "Kaung",
  "license": "UNLICENSED",
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "eslint": "^9.39.2",
    "globals": "^17.0.0",
    "jest": "^30.2.0",
    "prettier": "3.7.4",
    "supertest": "^7.2.2"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1019.0",
    "aws-jwt-verify": "^5.1.1",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.22.1",
    "helmet": "^8.1.0",
    "http-auth": "^4.2.1",
    "http-auth-passport": "^1.0.7",
    "jg": "^0.0.0",
    "markdown-it": "^14.1.1",
    "passport": "^0.7.0",
    "passport-http-bearer": "^1.0.1",
    "pino": "^10.1.0",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "stoppable": "^1.1.0"
  }
}
